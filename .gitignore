# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# SCORM training packages contain pre-built dist/ bundles — track them
!portal/client/public/training/**/dist/
!portal/client/public/training/**/dist/**

# Vite cache
.vite/

# Environment variables — never commit these
.env
.env.local
.env.*.local

# Editor
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SQLite database files — never commit live database data
portal/data/*.db
portal/data/*.db-shm
portal/data/*.db-wal
portal/data/*.bak
# Large video files — host on CDN, not in git
*.mp4
*.mov
*.webm
*.avi
*.m4v
