# JWT secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://sliquid-b2b.pages.dev,https://your-portal.pages.dev

# Port (Railway sets this automatically)
PORT=3001

# Absolute path to the SQLite database file.
# On Railway: add a Volume mounted at /data in the dashboard, then set this to /data/portal.db
# Locally: leave unset — defaults to portal/data/portal.db
DB_PATH=/data/portal.db

# SMTP settings for quiz pass emails (all optional — emails are skipped if unset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Sliquid Partner Portal <noreply@sliquid.com>
