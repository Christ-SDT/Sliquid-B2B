# JWT secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://sliquid-b2b.pages.dev,https://your-portal.pages.dev

# Port (Railway sets this automatically)
PORT=3001

# Absolute path to the SQLite database file.
# On Railway: add a Volume mounted at /data in the dashboard, then set this to /data/portal.db
# Locally: leave unset — defaults to portal/data/portal.db
DB_PATH=/data/portal.db

# EmailJS — portal server email sending (all optional — emails skipped if unset)
# Get these from https://emailjs.com → Account → API Keys
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_SERVICE_ID=your_emailjs_service_id

# URL of the deployed portal client (used in email links)
PORTAL_URL=https://sliquid-portal.pages.dev
